# Optional overrides. The demo runs without an .env file.
PORT=8787
HOST=127.0.0.1

# Local SQLite file. Defaults to server/data/app.db.
# SQLITE_PATH=/absolute/path/to/client-portal-demo.db

# Optional permission-aware AI assistant. Hidden when the API key is unset.
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-5.6-terra
# OPENAI_REASONING_EFFORT=low

# Optional read-only ConnectWise PSA integration. The base URL includes
# /v4_6_release/apis/3.0. Client mappings are configured in Admin > Clients.
# CONNECTWISE_BASE_URL=https://api-na.myconnectwise.net/v4_6_release/apis/3.0
# CONNECTWISE_COMPANY_ID=your-psa-company-id
# CONNECTWISE_PUBLIC_KEY=...
# CONNECTWISE_PRIVATE_KEY=...
# CONNECTWISE_CLIENT_ID=...

# Optional read-only NinjaOne integration. The token URL defaults to
# <NINJAONE_BASE_URL origin>/ws/oauth/token when omitted.
# NINJAONE_BASE_URL=https://app.ninjarmm.com
# NINJAONE_TOKEN_URL=https://app.ninjarmm.com/ws/oauth/token
# NINJAONE_CLIENT_ID=...
# NINJAONE_CLIENT_SECRET=...
